{
  "compilerOptions": {
    /* ── Language & Target ──────────────────────────────────────────────── */
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,

    /* ── Strict mode ────────────────────────────────────────────────────── */
    "strict": true,
    "noEmit": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,

    /* ── Module resolution ──────────────────────────────────────────────── */
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",

    /* ── Next.js ────────────────────────────────────────────────────────── */
    "incremental": true,
    "plugins": [{ "name": "next" }],

    /* ── Path aliases ───────────────────────────────────────────────────── */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
, "next.config.mjs"  ],
  "exclude": ["node_modules"]
}
